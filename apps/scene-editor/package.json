{
	"name": "@world-lab/scene-editor-app",
	"private": true,
	"version": "0.1.0",
	"license": "MIT",
	"description": "World Lab scene and solar-system editor with planet-scale WebGPU rendering.",
	"homepage": "https://planets.ferreyrapons.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/saabi/world-lab.git",
		"directory": "apps/scene-editor"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "node scripts/ensure-rolldown-binding.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"build:wasm": "asc assembly/scheduler.ts --outFile src/lib/planet/patches/wasm/scheduler.wasm --runtime stub --optimize",
		"sundog:export": "node --experimental-strip-types --no-warnings scripts/sundog/export-catalog.ts",
		"test": "vitest run"
	},
	"dependencies": {
		"@world-lab/editor-ui": "^0.0.0",
		"@world-lab/graph": "^0.0.0",
		"@world-lab/runtime-cpu": "^0.0.0",
		"@world-lab/schema": "^0.0.0",
		"@world-lab/subdivide": "^0.0.0",
		"happy-dom": "20.10.6",
		"three": "^0.185.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^26.0.1",
		"@types/three": "^0.185.0",
		"@webgpu/types": "^0.1.71",
		"assemblyscript": "^0.28.19",
		"glslify": "^7.1.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.2",
		"vitest": "^4.1.9"
	},
	"optionalDependencies": {
		"@rolldown/binding-darwin-arm64": "1.1.3",
		"@rolldown/binding-darwin-x64": "1.1.3",
		"@rolldown/binding-linux-x64-gnu": "1.1.3",
		"@rolldown/binding-linux-x64-musl": "1.1.3",
		"@rolldown/binding-win32-x64-msvc": "1.1.3"
	}
}
